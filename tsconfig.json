{
	"compilerOptions": {
		"allowJs": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"esModuleInterop": true,
		"isolatedModules": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"outDir": "dist",
		"rootDir": "src",
		"target": "ES2022",
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
