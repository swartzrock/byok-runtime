{
	"name": "@swartzrock/byok-runtime",
	"version": "0.3.0",
	"description": "Let users bring their own AI keys — one TypeScript API for OpenAI, Anthropic, Gemini, Ollama, and more.",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		}
	},
	"scripts": {
		"attw": "attw --pack --profile esm-only --ignore-rules cjs-resolves-to-esm no-resolution",
		"build": "tsup",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"check": "bun run format:check && bun run lint && bun run build && bun run typecheck && bun run typecheck:examples && bun run test && bun run pack:check && bun run publint && bun run attw",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"lint": "eslint . --max-warnings=0",
		"pack:check": "npm pack --dry-run",
		"prepack": "bun run build",
		"publint": "publint",
		"test": "vitest run --config vitest.config.ts",
		"typecheck:examples": "tsc -p tsconfig.examples.json",
		"typecheck": "tsc -p tsconfig.json"
	},
	"files": [
		"dist",
		"README.md",
		"API.md",
		"CHANGELOG.md",
		"LICENSE",
		"package.json"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"ai",
		"llm",
		"byok",
		"bring-your-own-key",
		"anthropic",
		"openai",
		"gemini",
		"openrouter",
		"ollama",
		"lm-studio",
		"text-generation",
		"structured-output",
		"model-discovery",
		"typescript"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/swartzrock/byok-runtime.git"
	},
	"bugs": {
		"url": "https://github.com/swartzrock/byok-runtime/issues"
	},
	"dependencies": {
		"ollama": "^0.6.3",
		"openai": "^6.45.0",
		"tslib": "2.6.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.4",
		"@changesets/cli": "^2.29.5",
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.0.4",
		"eslint": "^10.6.0",
		"prettier": "^3.9.4",
		"publint": "^0.3.21",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.62.1",
		"vitest": "^3.2.4"
	}
}
